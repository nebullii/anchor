<% content_for :title, "Repositories — Anchor" %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-white">Repositories</h1>
    <p class="text-sm text-gray-500 mt-1">GitHub repositories available for deployment.</p>
  </div>
  <%= button_to sync_repositories_path, method: :post,
        class: "inline-flex items-center gap-2 text-sm text-gray-400 hover:text-white border border-gray-700 hover:border-gray-500 px-4 py-2 rounded-lg transition-colors" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
    </svg>
    Sync from GitHub
  <% end %>
</div>

<div class="rounded-xl border border-gray-800 divide-y divide-gray-800 overflow-hidden">
  <% if @repositories.empty? %>
    <div class="px-4 py-10 text-center">
      <p class="text-sm text-gray-500 mb-3">No repositories synced yet.</p>
      <%= button_to sync_repositories_path, method: :post,
            class: "text-indigo-400 hover:text-indigo-300 text-sm underline underline-offset-2" do %>
        Sync from GitHub
      <% end %>
    </div>
  <% else %>
    <% @repositories.each do |repo| %>
      <div class="flex items-center justify-between px-4 py-3 hover:bg-gray-800/30 transition-colors">
        <div class="flex items-center gap-3 min-w-0">
          <div class="flex-shrink-0">
            <% if repo.private %>
              <svg class="w-4 h-4 text-gray-600" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/>
              </svg>
            <% else %>
              <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
              </svg>
            <% end %>
          </div>
          <div class="min-w-0">
            <a href="<%= repo.html_url %>" target="_blank" rel="noopener"
               class="text-sm text-gray-200 hover:text-white font-medium">
              <%= repo.full_name %>
            </a>
            <div class="flex items-center gap-3 mt-0.5">
              <% if repo.language.present? %>
                <span class="text-xs text-gray-600"><%= repo.language %></span>
              <% end %>
              <span class="text-xs text-gray-700"><%= repo.default_branch %></span>
            </div>
          </div>
        </div>
        <%= link_to new_project_path(repository_id: repo.id),
              class: "flex-shrink-0 text-xs text-indigo-400 hover:text-indigo-300 border border-indigo-800/50 hover:border-indigo-600 px-3 py-1 rounded transition-colors" do %>
          Deploy
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>
