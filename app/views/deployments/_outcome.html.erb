<%# locals: (deployment:) %>
<%# Turbo Stream target: broadcast_replace_to "deployment_#{id}", target: "deployment_outcome" %>

<% if deployment.success? && deployment.service_url.present? %>
  <div class="mb-6 flex items-center gap-3 p-4 rounded-xl bg-emerald-950/50 border border-emerald-800/50"
       data-controller="clipboard"
       data-clipboard-content-value="<%= deployment.service_url %>">
    <div class="w-2 h-2 rounded-full bg-emerald-400 flex-shrink-0 animate-pulse"></div>
    <div class="flex-1 min-w-0">
      <p class="text-xs text-emerald-600 font-semibold uppercase tracking-wide mb-0.5">Live</p>
      <a href="<%= deployment.service_url %>" target="_blank" rel="noopener"
         class="text-sm text-emerald-400 hover:text-emerald-300 font-mono truncate block">
        <%= deployment.service_url %>
      </a>
    </div>
    <div class="flex items-center gap-2 flex-shrink-0">
      <button data-action="clipboard#copy"
              data-clipboard-target="button"
              class="text-xs text-gray-500 hover:text-gray-300 transition-colors px-2 py-1 rounded border border-gray-700 hover:border-gray-500">
        Copy
      </button>
      <a href="<%= deployment.service_url %>" target="_blank" rel="noopener"
         class="text-emerald-600 hover:text-emerald-400 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
        </svg>
      </a>
    </div>
  </div>

  <div class="mb-6 rounded-xl border border-gray-800 p-4 text-sm">
    <p class="text-xs text-gray-500 font-semibold uppercase tracking-wide mb-3">Deployment Metadata</p>
    <div class="space-y-1.5">
      <div class="flex justify-between gap-2">
        <span class="text-gray-500">Service</span>
        <span class="text-gray-200 font-mono text-xs"><%= deployment.project.service_name %></span>
      </div>
      <div class="flex justify-between gap-2">
        <span class="text-gray-500">Region</span>
        <span class="text-gray-200 font-mono text-xs"><%= deployment.project.gcp_region %></span>
      </div>
      <div class="flex justify-between gap-2">
        <span class="text-gray-500">Runtime</span>
        <span class="text-gray-200 font-mono text-xs"><%= deployment.project.runtime || "unknown" %></span>
      </div>
      <div class="flex justify-between gap-2">
        <span class="text-gray-500">Last Deploy</span>
        <span class="text-gray-200 text-xs"><%= deployment.finished_at&.strftime("%b %-d, %Y %H:%M UTC") || "—" %></span>
      </div>
    </div>
  </div>

<% elsif deployment.status == "cancelled" %>
  <div class="mb-6 flex items-center gap-3 p-4 rounded-xl bg-gray-900/50 border border-gray-700">
    <svg class="w-4 h-4 text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
    </svg>
    <p class="text-sm text-gray-400">Deployment was cancelled.</p>
  </div>

<% elsif deployment.status == "failed" %>
  <div class="mb-6 p-4 rounded-xl bg-red-950/50 border border-red-800/50">
    <p class="text-xs text-red-500 font-semibold uppercase tracking-wide mb-2">Deployment Failed</p>
    <pre class="text-sm text-red-300 whitespace-pre-wrap font-mono leading-relaxed"><%= deployment.error_message %></pre>
    <% if deployment.error_category.present? %>
      <p class="text-xs text-red-400 mt-2">
        Suggested fix: <%= Deployments::ErrorCategorizer.user_hint(deployment.error_category) %>
      </p>
    <% end %>

    <% if deployment.ai_error_explanation.present? %>
      <div class="mt-4 pt-4 border-t border-red-800/40">
        <p class="text-xs text-red-400 font-semibold uppercase tracking-wide mb-2">
          <svg class="w-3.5 h-3.5 inline-block mr-1 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          What went wrong
        </p>
        <p class="text-sm text-red-200/80 leading-relaxed"><%= deployment.ai_error_explanation %></p>
      </div>
    <% elsif deployment.failed? %>
      <%# Placeholder while ExplainErrorJob is still running %>
      <div class="mt-4 pt-4 border-t border-red-800/40">
        <p class="text-xs text-red-600 animate-pulse">Analyzing failure…</p>
      </div>
    <% end %>

    <div class="mt-4 pt-4 border-t border-red-800/40 flex flex-wrap items-center gap-2">
      <% missing_key = Deployments::ErrorCategorizer.extract_missing_env_var(deployment.error_message) %>
      <% if deployment.error_category == "missing_env_var" && missing_key.present? %>
        <%= link_to "Add #{missing_key}", project_secrets_path(deployment.project, prefill_key: missing_key),
              class: "inline-flex items-center text-xs text-red-100 bg-red-800/60 hover:bg-red-700/70 px-3 py-1.5 rounded border border-red-700" %>
      <% end %>
      <%= button_to "Fix and Redeploy", deploy_project_path(deployment.project), method: :post,
            class: "inline-flex items-center text-xs text-white bg-indigo-600 hover:bg-indigo-500 px-3 py-1.5 rounded" %>
    </div>
  </div>

<% elsif deployment.in_progress? %>
  <div class="mb-6 flex items-center gap-3 p-4 rounded-xl bg-gray-900/50 border border-gray-800">
    <svg class="w-4 h-4 text-yellow-500 animate-spin flex-shrink-0" fill="none" viewBox="0 0 24 24">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
    </svg>
    <p class="text-sm text-gray-400">
      <%= deployment.status.to_s.humanize %>…
      <span class="text-gray-600 text-xs ml-1">stream updates are live</span>
    </p>
  </div>
<% end %>
