<div class="flex items-start gap-3 py-2 text-xs">
  <span class="text-gray-600 font-mono flex-shrink-0 w-24 pt-0.5">
    <%= event.occurred_at.strftime("%H:%M:%S") %>
  </span>

  <% case event.event_type
     when "status_changed" %>
    <div class="flex items-center gap-2 min-w-0">
      <span class="text-gray-500"><%= event.from_status %></span>
      <svg class="w-3 h-3 text-gray-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
      <span class="<%= %w[success running].include?(event.to_status) ? 'text-emerald-400' : event.to_status == 'failed' ? 'text-red-400' : 'text-indigo-300' %> font-medium">
        <%= event.to_status %>
      </span>
    </div>
  <% else %>
    <span class="text-gray-400"><%= event.event_type.humanize %></span>
    <% if event.metadata.present? %>
      <span class="text-gray-600 truncate"><%= event.metadata.to_json %></span>
    <% end %>
  <% end %>
</div>
