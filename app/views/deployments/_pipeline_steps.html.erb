<%# locals: (deployment:) %>
<%
  steps = [
    { key: "cloning",   label: "Clone repository",     icon: "📦" },
    { key: "detecting", label: "Detect framework",      icon: "🔍" },
    { key: "building",  label: "Build Docker image",    icon: "🐳" },
    { key: "deploying", label: "Deploy to Cloud Run",   icon: "🚀" },
    { key: "success",   label: "Live",                  icon: "✅" },
  ]

  order = %w[pending cloning detecting building deploying success failed cancelled]
  current_index = order.index(deployment.status) || 0

  def step_state(step_key, deployment, order, current_index)
    step_index = order.index(step_key) || 0
    if deployment.status == "failed" || deployment.status == "cancelled"
      step_index < current_index ? :done : :skipped
    elsif step_index < current_index
      :done
    elsif step_index == current_index
      :active
    else
      :pending
    end
  end
%>

<div id="deployment_pipeline" class="mb-6">
  <div class="flex items-center gap-0">
    <% steps.each_with_index do |step, i| %>
      <% state = step_state(step[:key], deployment, order, current_index) %>

      <%# Step node %>
      <div class="flex flex-col items-center flex-shrink-0">
        <div class="w-9 h-9 rounded-full flex items-center justify-center text-sm border-2 transition-all
          <%= case state
              when :done    then 'bg-emerald-900 border-emerald-500 text-emerald-300'
              when :active  then 'bg-indigo-900 border-indigo-400 text-indigo-200 ring-2 ring-indigo-500/30'
              when :skipped then 'bg-red-950 border-red-800 text-red-500'
              else               'bg-gray-900 border-gray-700 text-gray-600'
              end %>">
          <% if state == :active && !deployment.terminal? %>
            <svg class="w-4 h-4 animate-spin text-indigo-400" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
            </svg>
          <% elsif state == :done %>
            <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
            </svg>
          <% elsif state == :skipped %>
            <svg class="w-4 h-4 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          <% else %>
            <span class="text-xs font-bold text-gray-600"><%= i + 1 %></span>
          <% end %>
        </div>
        <p class="mt-1.5 text-xs text-center max-w-[72px] leading-tight
          <%= case state
              when :done    then 'text-emerald-400'
              when :active  then 'text-indigo-300 font-medium'
              when :skipped then 'text-red-500'
              else               'text-gray-600'
              end %>">
          <%= step[:label] %>
        </p>
      </div>

      <%# Connector line (not after last step) %>
      <% if i < steps.length - 1 %>
        <% line_done = order.index(steps[i + 1][:key]) <= current_index && !%w[failed cancelled].include?(deployment.status) %>
        <div class="flex-1 h-0.5 mb-5 <%= line_done ? 'bg-emerald-700' : 'bg-gray-800' %>"></div>
      <% end %>
    <% end %>
  </div>

  <% if deployment.status == "failed" %>
    <p class="mt-3 text-xs text-red-400 text-center">
      Failed during <span class="font-medium"><%= deployment.error_message&.split("\n")&.first || "deployment" %></span>
    </p>
  <% end %>
</div>
