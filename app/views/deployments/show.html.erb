<% content_for :title, "Deployment ##{@deployment.id} — Anchor" %>

<%# Subscribe to two streams:
    1. deployment_ID        → status badge + outcome panel updates
    2. deployment_ID_logs   → log line appends %>
<%= turbo_stream_from "deployment_#{@deployment.id}" %>
<%= turbo_stream_from "deployment_#{@deployment.id}_logs" %>

<%# ── Header ──────────────────────────────────────────────────── %>
<div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4 mb-6">
  <div>
    <%= link_to project_path(@project),
          class: "text-sm text-gray-500 hover:text-gray-300 flex items-center gap-1 mb-2" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      <%= @project.name %>
    <% end %>

    <div class="flex items-center gap-3 flex-wrap">
      <h1 class="text-xl font-bold text-white">Deployment #<%= @deployment.id %></h1>
      <%# Turbo Stream target: broadcast_replace_to "deployment_#{id}" %>
      <div id="deployment_<%= @deployment.id %>_status">
        <%= render "status_badge", deployment: @deployment %>
      </div>
    </div>

    <p class="text-sm text-gray-500 mt-1 font-mono truncate max-w-lg">
      <% if @deployment.commit_sha.present? %>
        <%= @deployment.commit_sha.first(7) %>
        <% if @deployment.commit_message.present? %>
          &middot; <%= @deployment.commit_message %>
        <% end %>
        <% if @deployment.commit_author.present? %>
          <span class="text-gray-600">by <%= @deployment.commit_author %></span>
        <% end %>
      <% end %>
    </p>
  </div>

  <div class="text-right text-xs text-gray-600 space-y-1 flex-shrink-0">
    <% if @deployment.in_progress? %>
      <%= button_to cancel_project_deployment_path(@project, @deployment),
            method: :post,
            data: { turbo_confirm: "Cancel this deployment?" },
            class: "mb-2 inline-flex items-center gap-1.5 text-xs text-red-400 hover:text-red-300 border border-red-800 hover:border-red-600 px-3 py-1.5 rounded-lg transition-colors" do %>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
        Cancel deployment
      <% end %>
    <% end %>

    <p>Triggered by <span class="text-gray-400"><%= @deployment.triggered_by %></span></p>
    <% if @deployment.branch.present? %>
      <p>Branch: <span class="text-gray-400 font-mono"><%= @deployment.branch %></span></p>
    <% end %>
    <% if @deployment.duration_seconds %>
      <p>Duration: <span class="text-gray-400"><%= @deployment.duration_label %></span></p>
    <% end %>
    <p><%= @deployment.created_at.strftime("%b %-d, %Y %H:%M UTC") %></p>
  </div>
</div>

<%# ── Pipeline steps — replaced by Turbo Stream on each status change %>
<div id="deployment_pipeline_wrapper">
  <%= render "pipeline_steps", deployment: @deployment %>
</div>

<%# ── Outcome panel (URL or error) — replaced by Turbo Stream on completion %>
<div id="deployment_outcome">
  <%= render "outcome", deployment: @deployment %>
</div>

<% if @deployment.deployment_plan.present? %>
  <div class="mb-6 rounded-xl border border-gray-800 p-4">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Deployment Plan Snapshot</h2>
      <span class="text-xs <%= @deployment.deployment_plan["deployment_readiness"].to_i >= 85 ? 'text-emerald-400' : 'text-amber-400' %>">
        <%= @deployment.deployment_plan["deployment_readiness"] %>% ready
      </span>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-xs text-gray-300">
      <p><span class="text-gray-500">Framework:</span> <%= @deployment.deployment_plan["framework"] %></p>
      <p><span class="text-gray-500">Runtime:</span> <%= @deployment.deployment_plan["runtime"] %></p>
      <p><span class="text-gray-500">Container:</span> <%= @deployment.deployment_plan["container"] %></p>
      <p><span class="text-gray-500">Target:</span> <%= @deployment.deployment_plan["target"] %></p>
    </div>
  </div>
<% end %>

<%# ── Log terminal ─────────────────────────────────────────────── %>
<div data-controller="log"
     data-log-running-value="<%= @deployment.in_progress? %>"
     data-log-started-at-value="<%= @deployment.started_at&.iso8601 || @deployment.created_at.iso8601 %>"
     class="rounded-xl border border-gray-800 overflow-hidden">

  <%# Terminal toolbar %>
  <div class="flex items-center justify-between px-4 py-3 bg-gray-900 border-b border-gray-800">
    <div class="flex items-center gap-2">
      <div class="w-3 h-3 rounded-full bg-red-500/60"></div>
      <div class="w-3 h-3 rounded-full bg-yellow-500/60"></div>
      <div class="w-3 h-3 rounded-full bg-green-500/60"></div>
      <span class="ml-2 text-xs text-gray-600 font-mono">build log</span>
    </div>
    <div class="flex items-center gap-4 text-xs text-gray-600">
      <% if @deployment.in_progress? %>
        <span class="flex items-center gap-1.5 text-yellow-500">
          <svg class="w-3 h-3 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
          </svg>
          <span data-log-target="elapsed"></span>
        </span>
      <% end %>
      <span data-log-target="lineCount"><%= @logs.count %> lines</span>
    </div>
  </div>

  <%# Log lines — Turbo Stream appends into this element %>
  <div id="deployment_logs"
       data-log-target="container"
       class="bg-gray-950 p-4 font-mono text-xs leading-5 h-[520px] overflow-y-auto scroll-smooth">

    <% @logs.each do |log| %>
      <%= render "log_line", log: log %>
    <% end %>

    <% if @deployment.in_progress? %>
      <div id="log_spinner" class="flex items-center gap-2 text-gray-600 pt-2">
        <svg class="w-3 h-3 animate-spin" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
        </svg>
        <span>Waiting for output…</span>
      </div>
    <% end %>
  </div>

  <%# Cloud Build link if available %>
  <% if @deployment.cloud_build_log_url.present? %>
    <div class="px-4 py-2 border-t border-gray-800 bg-gray-900 flex justify-end">
      <a href="<%= @deployment.cloud_build_log_url %>" target="_blank" rel="noopener"
         class="text-xs text-gray-500 hover:text-gray-300 flex items-center gap-1">
        View in Cloud Console
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
        </svg>
      </a>
    </div>
  <% end %>
</div>
