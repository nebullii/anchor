<% content_for :title, "Edit #{@project.name} — Anchor" %>

<div class="max-w-xl mx-auto">
  <div class="mb-6">
    <%= link_to project_path(@project), class: "text-sm text-gray-500 hover:text-gray-300 flex items-center gap-1" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      <%= @project.name %>
    <% end %>
    <h1 class="text-2xl font-bold text-white mt-3">Edit Project</h1>
  </div>

  <%= render "form", project: @project, repositories: @repositories %>

  <%# ── Auto-deploy webhook ────────────────────────────────────── %>
  <div class="mt-8 rounded-xl border border-gray-800 p-5">
    <h2 class="text-sm font-semibold text-gray-300 mb-1">GitHub Webhook</h2>
    <p class="text-xs text-gray-500 mb-4">
      Add this webhook to your GitHub repository to enable automatic deployments on push.
      Set content type to <code class="font-mono text-gray-400">application/json</code>.
    </p>

    <div class="space-y-3">
      <div>
        <p class="text-xs text-gray-500 mb-1">Payload URL</p>
        <div class="flex items-center gap-2"
             data-controller="clipboard"
             data-clipboard-content-value="<%= request.base_url %>/webhooks/github">
          <code class="flex-1 bg-gray-950 border border-gray-700 rounded-lg px-3 py-2 text-xs font-mono text-gray-300 truncate">
            <%= request.base_url %>/webhooks/github
          </code>
          <button data-action="clipboard#copy" data-clipboard-target="button"
                  class="flex-shrink-0 text-xs text-gray-500 hover:text-gray-300 border border-gray-700 hover:border-gray-500 px-2 py-1.5 rounded-lg transition-colors">
            Copy
          </button>
        </div>
      </div>

      <% if @project.webhook_secret.present? %>
        <div>
          <p class="text-xs text-gray-500 mb-1">Secret</p>
          <div class="flex items-center gap-2"
               data-controller="clipboard"
               data-clipboard-content-value="<%= @project.webhook_secret %>">
            <code class="flex-1 bg-gray-950 border border-gray-700 rounded-lg px-3 py-2 text-xs font-mono text-gray-300 truncate">
              <%= @project.webhook_secret %>
            </code>
            <button data-action="clipboard#copy" data-clipboard-target="button"
                    class="flex-shrink-0 text-xs text-gray-500 hover:text-gray-300 border border-gray-700 hover:border-gray-500 px-2 py-1.5 rounded-lg transition-colors">
              Copy
            </button>
          </div>
        </div>
      <% end %>

      <p class="text-xs text-gray-600">
        Only push events to the <code class="font-mono"><%= @project.production_branch %></code> branch trigger a deployment.
        Auto-deploy must also be enabled above.
      </p>
    </div>
  </div>

  <%# ── Danger zone ────────────────────────────────────────────── %>
  <div class="mt-6 rounded-xl border border-red-900/50 p-5">
    <h2 class="text-sm font-semibold text-red-400 mb-3">Danger Zone</h2>
    <%= button_to project_path(@project), method: :delete,
          data: { turbo_confirm: "Delete #{@project.name}? This cannot be undone." },
          class: "text-sm text-red-400 hover:text-red-300 border border-red-900 hover:border-red-700 px-4 py-2 rounded-lg transition-colors" do %>
      Delete project
    <% end %>
  </div>
</div>
