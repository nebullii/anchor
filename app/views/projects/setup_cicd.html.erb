<% content_for :title, "Setup CI/CD — #{@project.name} — Anchor" %>
<%= turbo_stream_from "project_#{@project.id}_cicd" %>

<%# ── Header ──────────────────────────────────────────────── %>
<div class="flex items-center gap-3 mb-8">
  <%= link_to @project,
        class: "text-gray-500 hover:text-gray-300 transition-colors" do %>
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
  <% end %>
  <div>
    <h1 class="text-xl font-bold text-white">Setup CI/CD — <%= @project.name %></h1>
    <p class="text-sm text-gray-500 mt-0.5">
      Claude scans your repo and commits a Dockerfile + GitHub Actions workflow.
      Deployments then happen automatically on every push.
    </p>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

  <%# ── Main: Setup Panel ───────────────────────────────────── %>
  <div class="lg:col-span-2 space-y-4">

    <%# GCP not configured warning %>
    <% unless current_user.google_connected? %>
      <div class="flex items-start gap-3 p-4 rounded-xl bg-amber-950/50 border border-amber-800/50">
        <svg class="w-4 h-4 text-amber-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
        </svg>
        <div>
          <p class="text-sm text-amber-300">GCP service account not configured.</p>
          <p class="text-xs text-amber-500 mt-0.5">
            The generated workflow needs a service account key.
            <%= link_to "Add it in Settings →", settings_path, class: "underline hover:text-amber-400" %>
          </p>
        </div>
      </div>
    <% end %>

    <%# Flash notices %>
    <% if notice.present? %>
      <div class="p-4 rounded-xl bg-emerald-950/50 border border-emerald-800/50 text-sm text-emerald-300">
        <%= notice %>
      </div>
    <% end %>
    <% if alert.present? %>
      <div class="p-4 rounded-xl bg-red-950/40 border border-red-800/50 text-sm text-red-300">
        <%= alert %>
      </div>
    <% end %>

    <%# The live panel — updated via Turbo Streams from SetupCicdJob %>
    <%= render "projects/cicd_setup_panel",
               project:        @project,
               cicd_result:    nil,
               status_message: nil %>

  </div>

  <%# ── Sidebar ──────────────────────────────────────────────── %>
  <div class="space-y-4">

    <%# How it works %>
    <div class="rounded-xl border border-gray-800 p-4">
      <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">How it works</h3>
      <ol class="space-y-2.5 text-xs text-gray-400 list-none">
        <li class="flex items-start gap-2">
          <span class="flex-shrink-0 w-5 h-5 rounded-full bg-indigo-950 border border-indigo-700 text-indigo-400 text-xs flex items-center justify-center font-bold">1</span>
          <span>Claude scans your repository and detects your framework, dependencies, and required environment variables.</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="flex-shrink-0 w-5 h-5 rounded-full bg-indigo-950 border border-indigo-700 text-indigo-400 text-xs flex items-center justify-center font-bold">2</span>
          <span>You add the listed secrets to your GitHub repository (Settings → Secrets and variables → Actions).</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="flex-shrink-0 w-5 h-5 rounded-full bg-indigo-950 border border-indigo-700 text-indigo-400 text-xs flex items-center justify-center font-bold">3</span>
          <span>Anchor commits a Dockerfile and GitHub Actions workflow to your repo.</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="flex-shrink-0 w-5 h-5 rounded-full bg-indigo-950 border border-indigo-700 text-indigo-400 text-xs flex items-center justify-center font-bold">4</span>
          <span>Push to <code class="font-mono text-indigo-400"><%= @project.production_branch %></code> — GitHub Actions deploys to Cloud Run automatically.</span>
        </li>
      </ol>
    </div>

    <%# Project config summary %>
    <div class="rounded-xl border border-gray-800 p-4">
      <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Project Config</h3>
      <div class="space-y-2 text-xs">
        <div class="flex justify-between gap-2">
          <span class="text-gray-500">Repository</span>
          <span class="text-gray-200 font-mono truncate"><%= @project.repository.full_name %></span>
        </div>
        <div class="flex justify-between gap-2">
          <span class="text-gray-500">Branch</span>
          <span class="text-gray-200 font-mono"><%= @project.production_branch %></span>
        </div>
        <div class="flex justify-between gap-2">
          <span class="text-gray-500">GCP Project</span>
          <span class="text-gray-200 font-mono truncate"><%= @project.gcp_project_id %></span>
        </div>
        <div class="flex justify-between gap-2">
          <span class="text-gray-500">Region</span>
          <span class="text-gray-200 font-mono"><%= @project.gcp_region %></span>
        </div>
        <div class="flex justify-between gap-2">
          <span class="text-gray-500">Service</span>
          <span class="text-gray-200 font-mono truncate"><%= @project.service_name %></span>
        </div>
      </div>
      <div class="mt-3 pt-3 border-t border-gray-800">
        <%= link_to "Edit config →", edit_project_path(@project),
              class: "text-xs text-indigo-400 hover:text-indigo-300" %>
      </div>
    </div>

    <%# Required GitHub secrets reference (static, always visible) %>
    <div class="rounded-xl border border-gray-800 p-4">
      <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Core GitHub Secrets</h3>
      <div class="space-y-2 text-xs text-gray-400">
        <div>
          <code class="font-mono text-amber-300">GCP_PROJECT_ID</code>
          <p class="text-gray-600 mt-0.5">Your GCP project ID: <code class="font-mono text-gray-500"><%= @project.gcp_project_id %></code></p>
        </div>
        <div>
          <code class="font-mono text-amber-300">GCP_SA_KEY</code>
          <p class="text-gray-600 mt-0.5">Service account JSON key with Cloud Run &amp; Artifact Registry permissions.</p>
          <a href="https://console.cloud.google.com/iam-admin/serviceaccounts?project=<%= @project.gcp_project_id %>"
             target="_blank" rel="noopener"
             class="text-indigo-500 hover:text-indigo-400 underline">Open GCP Console ↗</a>
        </div>
        <p class="text-gray-600 pt-1">Claude will detect and list additional app-specific secrets after scanning.</p>
      </div>
    </div>

  </div>
</div>
