<% content_for :title, "New Project — Anchor" %>

<div class="max-w-xl mx-auto">
  <div class="mb-6">
    <%= link_to projects_path, class: "text-sm text-gray-500 hover:text-gray-300 flex items-center gap-1" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Projects
    <% end %>
    <h1 class="text-2xl font-bold text-white mt-3">New Project</h1>
  </div>

  <%= render "form", project: @project, repositories: @repositories %>
</div>
