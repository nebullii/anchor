<%# locals: (project:) %>
<div class="surface-card p-5 transition-all hover:-translate-y-0.5 hover:border-slate-500/70">
  <div class="flex items-start justify-between mb-3">
    <div class="flex-1 min-w-0">
      <%= link_to project_path(project), class: "block" do %>
        <h3 class="truncate text-base font-semibold text-white transition-colors hover:text-blue-300">
          <%= project.name %>
        </h3>
      <% end %>
      <p class="mt-0.5 truncate font-mono text-[11px] text-slate-400"><%= project.repository&.full_name %></p>
    </div>
    <span class="ml-3 inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-xs font-medium ring-1 ring-inset flex-shrink-0 <%= status_badge_class(project.status) %>">
      <% if status_spinning?(project.status) %>
        <svg class="w-3 h-3 animate-spin" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
        </svg>
      <% end %>
      <%= project.status %>
    </span>
  </div>

  <% if project.framework.present? %>
    <p class="mb-3 text-xs text-slate-400">
      <%= raw framework_icon(project.framework) %> <%= project.framework %> &middot; <%= project.gcp_region %>
    </p>
  <% end %>

  <% if project.latest_url.present? %>
    <a href="<%= project.latest_url %>" target="_blank" rel="noopener"
       class="mb-3 block truncate font-mono text-xs text-blue-300 hover:text-blue-200">
      <%= project.latest_url %>
    </a>
  <% end %>

  <div class="mt-4 flex items-center justify-between border-t border-slate-700/70 pt-4">
    <span class="text-xs text-slate-500">
      <% dep = project.latest_deployment %>
      <% if dep %>
        <%= time_ago_in_words(dep.created_at) %> ago
      <% else %>
        Never deployed
      <% end %>
    </span>
    <%= button_to deploy_project_path(project), method: :post,
          class: "btn-secondary !px-3 !py-1 !text-xs" do %>
      Deploy
    <% end %>
  </div>
</div>
