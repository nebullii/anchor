<% content_for :title, "#{@project.name} — Anchor" %>
<%= turbo_stream_from "project_#{@project.id}_deployments" %>
<%= turbo_stream_from "project_#{@project.id}_analysis" %>
<%= turbo_stream_from "project_#{@project.id}_cicd" %>

<%# Placeholders replaced via Turbo Stream %>
<div id="missing_secrets_modal"></div>
<div id="dockerfile_preview_modal"></div>

<%# ── Header ──────────────────────────────────────────────────── %>
<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
  <div>
    <div class="flex items-center gap-3 flex-wrap">
      <h1 class="text-2xl font-bold text-white"><%= @project.name %></h1>
      <span class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-xs font-medium ring-1 ring-inset <%= status_badge_class(@project.status) %>">
        <%= @project.status %>
      </span>
    </div>
    <p class="text-sm text-gray-500 mt-1">
      <% if @project.repository %>
        <a href="<%= @project.repository.html_url %>" target="_blank" rel="noopener"
           class="hover:text-gray-300 transition-colors">
          <%= @project.repository.full_name %>
        </a>
        &middot; <%= @project.production_branch %> branch
      <% end %>
    </p>
  </div>

  <div class="flex items-center gap-3">
    <%= link_to edit_project_path(@project),
          class: "text-sm text-gray-400 hover:text-white border border-gray-700 hover:border-gray-500 px-4 py-2 rounded-lg transition-colors" do %>
      Settings
    <% end %>

    <%# CI/CD setup button %>
    <%= link_to setup_cicd_project_path(@project),
          class: "inline-flex items-center gap-2 #{@project.cicd_committed? ? 'bg-emerald-900/50 hover:bg-emerald-900 border border-emerald-700 text-emerald-300' : 'bg-gray-800 hover:bg-gray-700 border border-gray-700 text-gray-300'} text-sm font-medium px-4 py-2 rounded-lg transition-colors" do %>
      <% if @project.cicd_committed? %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        CI/CD Active
      <% else %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
        </svg>
        Setup CI/CD
      <% end %>
    <% end %>

    <%# deploy_controller disables the button while navigating away %>
    <div data-controller="deploy">
      <%= button_to deploy_project_path(@project), method: :post,
            data: { action: "deploy#submit" },
            class: "inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
        Deploy
      <% end %>
    </div>
  </div>
</div>

<%# ── GCP credentials warning ──────────────────────────────────── %>
<% unless current_user.google_connected? %>
  <div class="mb-6 flex items-center justify-between gap-4 p-4 rounded-xl bg-amber-950/50 border border-amber-800/50">
    <div class="flex items-center gap-3">
      <svg class="w-5 h-5 text-amber-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
      </svg>
      <p class="text-sm text-amber-300">
        GCP service account not configured — deployments will fail until you add your credentials.
      </p>
    </div>
    <%= link_to "Add credentials", settings_path,
          class: "flex-shrink-0 text-xs font-medium text-amber-900 bg-amber-400 hover:bg-amber-300 px-3 py-1.5 rounded transition-colors" %>
  </div>
<% end %>

<%# ── Live URL ─────────────────────────────────────────────────── %>
<% if @project.latest_url.present? %>
  <div class="mb-6 flex items-center gap-3 p-4 rounded-xl bg-emerald-950/50 border border-emerald-800/50"
       data-controller="clipboard"
       data-clipboard-content-value="<%= @project.latest_url %>">
    <div class="w-2 h-2 rounded-full bg-emerald-400 flex-shrink-0"></div>
    <div class="flex-1 min-w-0">
      <p class="text-xs text-emerald-600 font-semibold uppercase tracking-wide mb-0.5">Live URL</p>
      <a href="<%= @project.latest_url %>" target="_blank" rel="noopener"
         class="text-sm text-emerald-400 hover:text-emerald-300 font-mono truncate block">
        <%= @project.latest_url %>
      </a>
    </div>
    <button data-action="clipboard#copy"
            data-clipboard-target="button"
            class="flex-shrink-0 text-xs text-gray-500 hover:text-gray-300 transition-colors px-2 py-1 rounded border border-gray-700 hover:border-gray-500">
      Copy
    </button>
  </div>
<% end %>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

  <%# ── Deployments (Turbo Frame for isolated refreshes) ──────── %>
  <div class="lg:col-span-2">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider">Deployments</h2>
      <%= link_to "View all", project_deployments_path(@project),
            class: "text-xs text-indigo-400 hover:text-indigo-300" %>
    </div>
    <%= turbo_frame_tag "project_#{@project.id}_deployment_list" do %>
      <div id="project_<%= @project.id %>_deployment_list"
           class="rounded-xl border border-gray-800 divide-y divide-gray-800 overflow-hidden">
        <% if @deployments.empty? %>
          <p class="px-4 py-8 text-sm text-gray-500 text-center">No deployments yet.</p>
        <% else %>
          <% @deployments.each do |deployment| %>
            <%= render "deployments/row", deployment: deployment, show_project: false %>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# ── Sidebar ─────────────────────────────────────────────────── %>
  <div class="space-y-4">

    <%= render "projects/analysis_panel", project: @project %>

    <div class="rounded-xl border border-gray-800 p-4">
      <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Google Cloud</h3>
      <div class="space-y-2 text-sm">
        <div class="flex justify-between gap-2">
          <span class="text-gray-500 flex-shrink-0">Account</span>
          <% if current_user.google_connected? %>
            <span class="text-emerald-400 text-xs truncate"><%= current_user.connected_google_email %></span>
          <% else %>
            <%= link_to "Not configured", settings_path,
                  class: "text-xs text-amber-400 hover:text-amber-300 underline" %>
          <% end %>
        </div>
        <div class="flex justify-between gap-2">
          <span class="text-gray-500 flex-shrink-0">Project</span>
          <span class="text-gray-200 font-mono text-xs truncate"><%= @project.gcp_project_id %></span>
        </div>
        <div class="flex justify-between">
          <span class="text-gray-500">Region</span>
          <span class="text-gray-200 font-mono text-xs"><%= @project.gcp_region %></span>
        </div>
        <div class="flex justify-between gap-2">
          <span class="text-gray-500 flex-shrink-0">Service</span>
          <span class="text-gray-200 font-mono text-xs truncate"><%= @project.service_name %></span>
        </div>
      </div>
    </div>

    <%# CI/CD status card %>
    <div id="cicd_setup_panel_summary" class="rounded-xl border <%= @project.cicd_committed? ? 'border-emerald-800/50 bg-emerald-950/10' : 'border-gray-800' %> p-4">
      <div class="flex items-center justify-between mb-2">
        <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider">CI/CD</h3>
        <%= link_to "Configure →", setup_cicd_project_path(@project),
              class: "text-xs text-indigo-400 hover:text-indigo-300" %>
      </div>
      <% if @project.cicd_committed? %>
        <div class="flex items-center gap-1.5">
          <span class="w-2 h-2 rounded-full bg-emerald-400 flex-shrink-0"></span>
          <span class="text-sm text-emerald-300">Active via GitHub Actions</span>
        </div>
        <p class="text-xs text-gray-600 mt-1">Push to <code class="font-mono"><%= @project.production_branch %></code> to deploy.</p>
      <% elsif @project.cicd_scanning? %>
        <div class="flex items-center gap-1.5">
          <svg class="w-3 h-3 text-indigo-400 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
          </svg>
          <span class="text-sm text-indigo-300">Generating…</span>
        </div>
      <% else %>
        <p class="text-sm text-gray-500">Not configured.</p>
        <p class="text-xs text-gray-600 mt-1">Use CI/CD to deploy automatically on every git push.</p>
      <% end %>
    </div>

    <%= render "projects/free_tier_panel" %>

  </div>
</div>
