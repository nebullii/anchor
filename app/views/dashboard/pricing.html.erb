<% content_for :title, "Pricing — Anchor" %>

<%# ── Hero ──────────────────────────────────────────────────────────── %>
<section class="pt-16 pb-12 text-center">
  <div class="inline-flex items-center gap-2 border border-[var(--anchor-border)] rounded-full px-3 py-1 text-xs text-[var(--anchor-muted)] mb-8">
    <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 inline-block"></span>
    No subscription. Ever.
  </div>

  <h1 class="text-5xl sm:text-6xl font-bold tracking-tight text-[var(--anchor-text)] mb-6 leading-tight">
    Anchor is free.<br>
    <span class="text-[var(--anchor-muted)]">You pay your cloud, not us.</span>
  </h1>

  <p class="text-lg text-[var(--anchor-muted)] max-w-2xl mx-auto leading-relaxed">
    Render, Railway, and Heroku charge you every month — forever — to run your own code on their servers.
    Anchor deploys straight to your Google Cloud account.
    Your infra. Your data. Your bill — and it's a fraction of the cost.
  </p>
</section>

<div class="border-t border-[var(--anchor-border)]"></div>

<%# ── Cost comparison ────────────────────────────────────────────────── %>
<section class="py-16">
  <p class="text-xs font-semibold tracking-widest text-[var(--anchor-muted)] uppercase text-center mb-12">What you actually pay</p>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 max-w-5xl mx-auto">

    <%# Anchor + GCP %>
    <div class="border-2 border-emerald-700/60 rounded-2xl overflow-hidden">
      <div class="bg-emerald-950/30 px-6 py-5 border-b border-emerald-700/40">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-xs font-semibold text-emerald-400 uppercase tracking-wide mb-1">Anchor + Google Cloud Run</p>
            <p class="text-3xl font-bold text-[var(--anchor-text)]">$0 <span class="text-lg font-normal text-[var(--anchor-muted)]">/ month to start</span></p>
          </div>
          <span class="text-xs font-semibold text-emerald-400 bg-emerald-950/60 border border-emerald-700/50 px-3 py-1.5 rounded-full">Recommended</span>
        </div>
        <p class="text-sm text-[var(--anchor-muted)] mt-3">Anchor is free. GCP charges only for what you use — and most small apps fit inside the free tier.</p>
      </div>
      <div class="px-6 py-5">
        <p class="text-xs font-semibold text-[var(--anchor-text)] mb-4 uppercase tracking-wide">Typical monthly GCP costs</p>
        <ul class="space-y-3 text-sm">
          <% [
            ["Side project / hobby app", "$0 – $2", "Fits inside GCP free tier (2M requests/month, 360k vCPU-seconds)"],
            ["Small production app", "$3 – $15", "Light traffic, 1 vCPU, 512 MB RAM"],
            ["Growing startup", "$15 – $60", "Moderate traffic, autoscaling, multiple services"],
            ["High-traffic app", "Scales with use", "Pay-per-request, no idle cost when traffic drops to zero"],
          ].each do |tier, price, note| %>
            <li class="flex items-start justify-between gap-4 pb-3 border-b border-[var(--anchor-border)] last:border-0 last:pb-0">
              <div>
                <p class="font-medium text-[var(--anchor-text)]"><%= tier %></p>
                <p class="text-xs text-[var(--anchor-muted)] mt-0.5"><%= note %></p>
              </div>
              <span class="text-sm font-mono font-semibold text-emerald-400 whitespace-nowrap"><%= price %></span>
            </li>
          <% end %>
        </ul>
        <p class="text-xs text-[var(--anchor-muted)] mt-4">Cloud Run scales to zero — you pay nothing when your app isn't receiving traffic.</p>
      </div>
    </div>

    <%# The alternatives %>
    <div class="border border-[var(--anchor-border)] rounded-2xl overflow-hidden opacity-80">
      <div class="px-6 py-5 border-b border-[var(--anchor-border)]">
        <p class="text-xs font-semibold text-[var(--anchor-muted)] uppercase tracking-wide mb-1">Managed PaaS alternatives</p>
        <p class="text-3xl font-bold text-[var(--anchor-text)]">$7 – $500 <span class="text-lg font-normal text-[var(--anchor-muted)]">/ month</span></p>
        <p class="text-sm text-[var(--anchor-muted)] mt-3">Flat monthly fees that keep growing as you scale — on their servers, under their terms.</p>
      </div>
      <div class="px-6 py-5">
        <p class="text-xs font-semibold text-[var(--anchor-text)] mb-4 uppercase tracking-wide">Typical monthly costs</p>
        <ul class="space-y-3 text-sm">
          <% [
            ["Heroku Eco / Basic", "$5 – $25", "Sleeps after 30 min inactivity on cheap tiers"],
            ["Render Starter", "$7 – $25", "Per service, per month"],
            ["Railway Hobby", "$5 + usage", "Pro plan $20/month minimum"],
            ["Fly.io", "$5 – $30+", "Billed per machine-hour"],
          ].each do |platform, price, note| %>
            <li class="flex items-start justify-between gap-4 pb-3 border-b border-[var(--anchor-border)] last:border-0 last:pb-0">
              <div>
                <p class="font-medium text-[var(--anchor-text)]"><%= platform %></p>
                <p class="text-xs text-[var(--anchor-muted)] mt-0.5"><%= note %></p>
              </div>
              <span class="text-sm font-mono font-semibold text-[var(--anchor-muted)] whitespace-nowrap"><%= price %></span>
            </li>
          <% end %>
        </ul>
        <p class="text-xs text-[var(--anchor-muted)] mt-4">These platforms also own your deployment pipeline. Move off them and you start from scratch.</p>
      </div>
    </div>

  </div>
</section>

<div class="border-t border-[var(--anchor-border)]"></div>

<%# ── What's always free ──────────────────────────────────────────────── %>
<section class="py-16">
  <p class="text-xs font-semibold tracking-widest text-[var(--anchor-muted)] uppercase text-center mb-12">What's always free</p>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-4xl mx-auto">
    <% [
      ["Anchor itself", "No seat fees, no tiers, no \"pro\" features gated behind a paywall."],
      ["Unlimited projects", "Deploy as many repos as your GCP quota allows."],
      ["Live log streaming", "Real-time build and deploy logs straight to your browser."],
      ["Framework detection", "Automatic Dockerfile generation for every supported framework."],
      ["AI error explanation", "Claude reads your failed build and tells you what went wrong."],
      ["Encrypted secrets", "AES-256 encrypted env vars, stored in your own database."],
    ].each do |title, desc| %>
      <div class="border border-[var(--anchor-border)] rounded-xl p-5">
        <div class="flex items-center gap-2 mb-2">
          <svg class="w-4 h-4 text-emerald-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
          <h3 class="text-sm font-semibold text-[var(--anchor-text)]"><%= title %></h3>
        </div>
        <p class="text-sm text-[var(--anchor-muted)] leading-relaxed pl-6"><%= desc %></p>
      </div>
    <% end %>
  </div>
</section>

<div class="border-t border-[var(--anchor-border)]"></div>

<%# ── GCP free tier callout ──────────────────────────────────────────── %>
<section class="py-16 max-w-3xl mx-auto">
  <p class="text-xs font-semibold tracking-widest text-[var(--anchor-muted)] uppercase text-center mb-8">Google Cloud free tier</p>
  <div class="border border-[var(--anchor-border)] rounded-2xl overflow-hidden">
    <div class="grid grid-cols-1 sm:grid-cols-3 divide-y sm:divide-y-0 sm:divide-x divide-[var(--anchor-border)]">
      <% [
        ["2M", "requests / month", "Cloud Run"],
        ["360K", "vCPU-seconds / month", "Compute"],
        ["1 GB", "outbound / month", "Networking"],
      ].each do |amount, unit, label| %>
        <div class="px-6 py-6 text-center">
          <p class="text-3xl font-bold text-[var(--anchor-text)] font-mono"><%= amount %></p>
          <p class="text-xs text-[var(--anchor-muted)] mt-1"><%= unit %></p>
          <p class="text-xs text-emerald-400 mt-1 font-medium"><%= label %></p>
        </div>
      <% end %>
    </div>
    <div class="border-t border-[var(--anchor-border)] px-6 py-4 bg-[var(--anchor-surface)]/30">
      <p class="text-xs text-[var(--anchor-muted)] text-center">
        Most side projects and internal tools run entirely within these limits. Charges only apply when you exceed them.
        <a href="https://cloud.google.com/run/pricing" target="_blank" rel="noopener" class="text-[var(--anchor-text)] underline underline-offset-2 hover:no-underline ml-1">See GCP pricing →</a>
      </p>
    </div>
  </div>
</section>

<div class="border-t border-[var(--anchor-border)]"></div>

<%# ── FAQ ───────────────────────────────────────────────────────────── %>
<section class="py-16 max-w-2xl mx-auto">
  <p class="text-xs font-semibold tracking-widest text-[var(--anchor-muted)] uppercase text-center mb-12">Common questions</p>

  <div class="space-y-8">
    <% [
      [
        "Do I need a credit card to use Anchor?",
        "Not for Anchor itself — it's free. You will need billing enabled on your Google Cloud project to deploy (GCP requires this even for free-tier usage). GCP won't charge you until you exceed the free tier."
      ],
      [
        "Will I get a surprise bill from Google?",
        "Unlikely for small apps. Cloud Run scales to zero, so you pay nothing when your app isn't handling requests. For a side project or internal tool, expect $0–$5/month. You can set GCP billing alerts to notify you before costs exceed any threshold you choose."
      ],
      [
        "What GCP setup do I need before deploying?",
        "A GCP project with billing enabled and either a Google account connected via OAuth in Anchor settings, or a service account key. Anchor automatically enables the required APIs (Cloud Build, Cloud Run, Artifact Registry) and creates the container registry on your first deploy."
      ],
      [
        "Does Anchor store my code?",
        "Anchor clones your repo into a temporary directory during the build, submits it to Cloud Build in your GCP project, then deletes the local copy. Your source code is never stored on Anchor's servers."
      ],
      [
        "What happens when I stop using Anchor?",
        "Your Cloud Run services keep running — they're in your GCP account, not ours. You can manage, scale, or delete them directly in the Google Cloud Console at any time."
      ],
      [
        "Is there a limit on how many deploys I can run?",
        "20 deploys per day and 200 per month per account. These limits exist to protect GCP quota — contact us if you need them raised."
      ],
    ].each do |question, answer| %>
      <div class="border-b border-[var(--anchor-border)] pb-8 last:border-0">
        <h3 class="text-sm font-semibold text-[var(--anchor-text)] mb-2"><%= question %></h3>
        <p class="text-sm text-[var(--anchor-muted)] leading-relaxed"><%= answer %></p>
      </div>
    <% end %>
  </div>
</section>

<%# ── CTA ────────────────────────────────────────────────────────────── %>
<section class="py-16 text-center border-t border-[var(--anchor-border)]">
  <h2 class="text-3xl font-bold text-[var(--anchor-text)] mb-4">Start for free</h2>
  <p class="text-[var(--anchor-muted)] mb-8 max-w-md mx-auto">Sign in with GitHub, connect your Google Cloud account, and deploy your first app in under five minutes.</p>
  <%= button_to "/auth/github", data: { turbo: false },
        class: "inline-flex items-center gap-2.5 font-semibold text-sm px-6 py-3 rounded-lg transition-colors cursor-pointer",
        style: "background: var(--anchor-accent); color: var(--anchor-bg-1);" do %>
    <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
      <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.2 11.4.6.1.82-.26.82-.57v-2c-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.8 1.3 3.49 1 .1-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.14-.3-.54-1.52.1-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 013-.4c1.02 0 2.04.13 3 .4 2.29-1.55 3.3-1.23 3.3-1.23.64 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .31.2.68.82.56C20.56 21.8 24 17.3 24 12 24 5.37 18.63 0 12 0z"/>
    </svg>
    Deploy your first app free
  <% end %>
</section>
