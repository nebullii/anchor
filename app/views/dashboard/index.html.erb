          <path d="M37.1 33.7c-3.3 2.46-8.12 3.76-12.26 3.76-5.8 0-11.02-2.16-14.96-5.74-.3-.28-.02-.66.34-.44 4.26 2.48 9.52 3.98 14.94 3.98 3.66 0 7.68-.76 11.4-2.34.56-.24 1.02.36.54.78z" fill="#FF9900"/>
