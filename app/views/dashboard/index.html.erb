<% content_for :title, "Dashboard — Anchor" %>

<% unless logged_in? %>
  <%# ── Landing page for signed-out users ───────────────────── %>
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
    <div class="mb-6 flex items-center justify-center w-16 h-16 rounded-2xl bg-indigo-600/20 ring-1 ring-indigo-500/30">
      <svg class="w-8 h-8 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </div>
    <h1 class="text-4xl font-bold text-white mb-3">Deploy to Google Cloud Run</h1>
    <p class="text-gray-400 text-lg max-w-md mb-8">
      Connect a GitHub repository and Anchor handles the rest — framework detection,
      Docker build, and Cloud Run deployment.
    </p>
    <%= button_to "/auth/github", data: { turbo: false },
          class: "inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-500 text-white font-medium px-6 py-3 rounded-lg transition-colors" do %>
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.2 11.4.6.1.82-.26.82-.57v-2c-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.8 1.3 3.49 1 .1-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.14-.3-.54-1.52.1-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 013-.4c1.02 0 2.04.13 3 .4 2.29-1.55 3.3-1.23 3.3-1.23.64 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .31.2.68.82.56C20.56 21.8 24 17.3 24 12 24 5.37 18.63 0 12 0z"/>
      </svg>
      Sign in with GitHub
    <% end %>
  </div>
<% else %>
  <%# ── Authenticated dashboard ──────────────────────────────── %>
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-white">Dashboard</h1>
      <p class="text-sm text-gray-500 mt-0.5">Welcome back, <%= current_user.github_login %></p>
    </div>
    <%= link_to new_project_path,
          class: "inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      New Project
    <% end %>
  </div>

  <% if @projects.empty? %>
    <%# ── Empty state ────────────────────────────────────────── %>
    <div class="rounded-xl border border-dashed border-gray-800 p-12 text-center">
      <p class="text-gray-500 text-sm mb-4">No projects yet.</p>
      <%= link_to "Create your first project", new_project_path,
            class: "text-indigo-400 hover:text-indigo-300 text-sm underline underline-offset-2" %>
    </div>
  <% else %>
    <%# ── Project grid ───────────────────────────────────────── %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-10">
      <%= render @projects %>
    </div>

    <%# ── Recent deployments ─────────────────────────────────── %>
    <div>
      <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Recent Deployments</h2>
      <div class="rounded-xl border border-gray-800 divide-y divide-gray-800 overflow-hidden">
        <% if @recent_deployments.empty? %>
          <p class="px-4 py-6 text-sm text-gray-500 text-center">No deployments yet.</p>
        <% else %>
          <% @recent_deployments.each do |deployment| %>
            <%= render "deployments/row", deployment: deployment, show_project: true %>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>
