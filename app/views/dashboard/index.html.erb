      <%# Vultr %>
      <div class="relative border border-[var(--anchor-border)] rounded-xl p-4 flex flex-col items-center gap-3 opacity-60 hover:opacity-90 transition-opacity">
        <span class="absolute -top-2.5 left-1/2 -translate-x-1/2 text-[10px] font-semibold text-[var(--anchor-muted)] bg-[var(--anchor-bg-1)] px-2 border border-[var(--anchor-border)] rounded-full">Soon</span>
        <svg viewBox="0 0 48 48" class="w-8 h-8" xmlns="http://www.w3.org/2000/svg">
