<% content_for :title, "Deploy — Anchor" %>

<%# ── Wizard header ─────────────────────────────────────────────── %>
<div class="max-w-3xl mx-auto">
  <%= render "deploy_wizard/wizard_steps", current_step: 1 %>

  <div class="mb-8">
    <h1 class="text-2xl font-bold text-white">Pick a repository</h1>
    <p class="text-sm text-gray-500 mt-1">Choose the GitHub repo you want to deploy. Anchor will scan it and set everything up automatically.</p>
  </div>

  <%# Sync prompt if no repos %>
  <% if @repositories.empty? %>
    <div class="surface-card p-10 text-center border-dashed">
      <svg class="w-10 h-10 text-gray-700 mx-auto mb-4" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.2 11.4.6.1.82-.26.82-.57v-2c-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.8 1.3 3.49 1 .1-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.14-.3-.54-1.52.1-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 013-.4c1.02 0 2.04.13 3 .4 2.29-1.55 3.3-1.23 3.3-1.23.64 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .31.2.68.82.56C20.56 21.8 24 17.3 24 12 24 5.37 18.63 0 12 0z"/>
      </svg>
      <p class="text-sm text-gray-400 mb-4">No repositories synced yet.</p>
      <%= button_to sync_repositories_path, method: :post,
            class: "btn-primary" do %>
        Sync from GitHub
      <% end %>
    </div>
  <% else %>
    <%# Search input %>
    <div class="mb-4" data-controller="repo-filter">
      <input type="text"
             placeholder="Search repositories…"
             data-action="input->repo-filter#filter"
             data-repo-filter-target="input"
             class="w-full bg-[var(--anchor-bg-2)] border border-[var(--anchor-border)] text-white rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 placeholder-gray-600">

      <%# Repo list %>
      <div class="mt-4 rounded-xl border border-[var(--anchor-border)] divide-y divide-[var(--anchor-border)] overflow-hidden"
           data-repo-filter-target="list">
        <% @repositories.each do |repo| %>
          <div class="flex items-center justify-between px-4 py-3 hover:bg-gray-800/30 transition-colors"
               data-repo-filter-name="<%= repo.full_name.downcase %>">
            <div class="flex items-center gap-3 min-w-0">
              <% if repo.private %>
                <svg class="w-4 h-4 text-gray-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/>
                </svg>
              <% else %>
                <svg class="w-4 h-4 text-gray-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
                </svg>
              <% end %>

              <div class="min-w-0">
                <p class="text-sm text-gray-200 font-medium truncate"><%= repo.full_name %></p>
                <div class="flex items-center gap-3 mt-0.5">
                  <% if repo.language.present? %>
                    <span class="text-xs text-gray-600"><%= repo.language %></span>
                  <% end %>
                  <span class="text-xs text-gray-700 font-mono"><%= repo.default_branch %></span>
                  <% if repo.private %>
                    <span class="text-xs text-gray-700">private</span>
                  <% end %>
                </div>
              </div>
            </div>

            <%# Deploy button POSTs to wizard create action %>
            <%= button_to wizard_create_path,
                  method: :post,
                  params: { repository_id: repo.id },
                  class: "flex-shrink-0 inline-flex items-center gap-1.5 text-xs font-medium text-white bg-indigo-600 hover:bg-indigo-500 px-3 py-1.5 rounded-lg transition-colors" do %>
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
              Deploy
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="flex items-center justify-between mt-4">
      <p class="text-xs text-gray-600"><%= @repositories.size %> repositories synced</p>
      <%= button_to sync_repositories_path, method: :post,
            class: "text-xs text-gray-500 hover:text-gray-300 transition-colors" do %>
        Sync from GitHub
      <% end %>
    </div>
  <% end %>
</div>
