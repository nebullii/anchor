<% content_for :title, "Analyzing — Anchor" %>
<%# Auto-refresh every 3 seconds while analysis is running %>
<meta http-equiv="refresh" content="3">

<div class="max-w-3xl mx-auto">
  <%= render "deploy_wizard/wizard_steps", current_step: 2 %>

  <div class="mb-8">
    <h1 class="text-2xl font-bold text-white">Scanning your repository</h1>
    <p class="text-sm text-gray-500 mt-1">
      <strong class="text-gray-300"><%= @project.repository.full_name %></strong> —
      Anchor is cloning and analyzing your code.
    </p>
  </div>

  <div class="surface-card p-8">
    <div class="flex flex-col items-center text-center gap-6">
      <%# Spinner %>
      <div class="relative">
        <div class="w-16 h-16 rounded-full border-4 border-gray-800"></div>
        <div class="absolute inset-0 w-16 h-16 rounded-full border-4 border-indigo-500 border-t-transparent animate-spin"></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <svg class="w-6 h-6 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
          </svg>
        </div>
      </div>

      <div>
        <p class="text-white font-medium mb-1">Analyzing codebase with AI</p>
        <p class="text-sm text-gray-500">
          Detecting framework, runtime, environment variables, and database.<br>
          This usually takes 15–30 seconds.
        </p>
      </div>

      <%# What Anchor is doing %>
      <div class="w-full max-w-sm text-left space-y-2">
        <% [
          ["Cloning repository", true],
          ["Detecting framework & runtime", @project.analysis_status.in?(%w[analyzing complete])],
          ["Scanning for environment variables", @project.analysis_status.in?(%w[analyzing complete])],
          ["Running AI enrichment", @project.analysis_status == "analyzing"],
          ["Building deployment plan", false]
        ].each do |label, done| %>
          <div class="flex items-center gap-3 text-sm">
            <% if done %>
              <div class="w-4 h-4 rounded-full bg-indigo-600 flex items-center justify-center flex-shrink-0">
                <svg class="w-2.5 h-2.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <span class="text-gray-400"><%= label %></span>
            <% else %>
              <div class="w-4 h-4 rounded-full border border-gray-700 flex-shrink-0"></div>
              <span class="text-gray-600"><%= label %></span>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <p class="text-center text-xs text-gray-700 mt-4">
    This page refreshes automatically. You can also
    <%= link_to "check manually", wizard_analyzing_path(@project), class: "text-indigo-500 hover:text-indigo-400" %>.
  </p>
</div>
