<% content_for :title, "Secrets — #{@project.name} — Anchor" %>

<div class="max-w-2xl mx-auto">
  <div class="mb-6">
    <%= link_to project_path(@project), class: "text-sm text-gray-500 hover:text-gray-300 flex items-center gap-1 mb-2" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      <%= @project.name %>
    <% end %>
    <h1 class="text-2xl font-bold text-white">Secrets</h1>
    <p class="text-sm text-gray-500 mt-1">
      Environment variables are encrypted at rest and injected into Cloud Run at deploy time.
    </p>
  </div>

  <%# ── Add secret form ─────────────────────────────────────── %>
  <div class="rounded-xl border border-gray-800 p-5 mb-6">
    <h2 class="text-sm font-semibold text-gray-300 mb-4">Add Secret</h2>
    <%= form_with model: [@project, @secret], class: "flex gap-3" do |f| %>
      <% if @secret.errors.any? %>
        <div class="w-full rounded-md bg-red-950 border border-red-800 px-4 py-2 text-sm text-red-300 mb-3">
          <%= @secret.errors.full_messages.first %>
        </div>
      <% end %>
      <%= f.text_field :key, placeholder: "DATABASE_URL",
            class: "flex-1 bg-gray-900 border border-gray-700 text-white font-mono rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 placeholder-gray-600 uppercase" %>
      <%= f.text_field :value, placeholder: "value",
            class: "flex-1 bg-gray-900 border border-gray-700 text-white font-mono rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 placeholder-gray-600" %>
      <%= f.submit "Add",
            class: "bg-indigo-600 hover:bg-indigo-500 text-white text-sm px-4 py-2 rounded-lg transition-colors cursor-pointer flex-shrink-0" %>
    <% end %>
  </div>

  <%# ── Secrets list ────────────────────────────────────────── %>
  <div class="rounded-xl border border-gray-800 divide-y divide-gray-800 overflow-hidden">
    <% if @secrets.empty? %>
      <p class="px-4 py-8 text-sm text-gray-500 text-center">No secrets yet.</p>
    <% else %>
      <% @secrets.each do |secret| %>
        <div class="flex items-center justify-between px-4 py-3 group">
          <div class="flex items-center gap-4 min-w-0">
            <span class="font-mono text-sm text-indigo-300 flex-shrink-0"><%= secret.key %></span>
            <span class="font-mono text-xs text-gray-600 truncate"><%= secret.masked_value %></span>
          </div>
          <%= button_to project_secret_path(@project, secret), method: :delete,
                data: { turbo_confirm: "Delete #{secret.key}?" },
                class: "text-xs text-gray-600 hover:text-red-400 transition-colors opacity-0 group-hover:opacity-100 flex-shrink-0" do %>
            Remove
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>

  <p class="mt-4 text-xs text-gray-600">
    Changes take effect on the next deployment. Keys must be UPPER_SNAKE_CASE.
  </p>

  <%# ── Detected vars from analysis ──────────────────────────── %>
  <% if @detected_vars.any? %>
    <div class="mt-6 rounded-xl border border-gray-800 p-4">
      <h2 class="text-sm font-semibold text-gray-300 mb-1">Detected from Repository</h2>
      <p class="text-xs text-gray-500 mb-4">
        These environment variables were found during analysis. Click to pre-fill the form above.
      </p>
      <div class="space-y-2">
        <% @detected_vars.each do |var| %>
          <% key = var["key"] %>
          <% already_set = @secrets.map(&:key).include?(key) %>
          <div class="flex items-center justify-between gap-3 py-1">
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2">
                <code class="text-xs text-gray-300 font-mono"><%= key %></code>
                <% if var["required"] %>
                  <span class="text-xs text-amber-500">required</span>
                <% end %>
              </div>
              <% if var["hint"].present? %>
                <p class="text-xs text-gray-600 mt-0.5"><%= var["hint"] %></p>
              <% end %>
            </div>
            <% if already_set %>
              <span class="text-xs text-emerald-400 flex-shrink-0">✓ set</span>
            <% else %>
              <%= link_to "+ Add",
                    project_secrets_path(@project, prefill_key: key),
                    class: "text-xs text-indigo-400 hover:text-indigo-300 flex-shrink-0" %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
