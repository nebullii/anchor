<% content_for :title, "Settings — Anchor" %>

<div class="max-w-2xl">
  <h1 class="text-2xl font-bold text-white mb-8">Settings</h1>

  <%# ── GCP Credentials ─────────────────────────────────────────── %>
  <div class="rounded-xl border border-gray-800 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-800">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-sm font-semibold text-white">Google Cloud Credentials</h2>
          <p class="text-xs text-gray-500 mt-0.5">Required to build and deploy your projects</p>
        </div>
        <% if current_user.google_connected? %>
          <span class="inline-flex items-center gap-1.5 text-xs font-medium text-emerald-400 bg-emerald-950/50 border border-emerald-800/50 px-2.5 py-1 rounded-full">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
            Connected
          </span>
        <% else %>
          <span class="inline-flex items-center gap-1.5 text-xs font-medium text-amber-400 bg-amber-950/50 border border-amber-800/50 px-2.5 py-1 rounded-full">
            <span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span>
            Not configured
          </span>
        <% end %>
      </div>
    </div>

    <div class="px-6 py-5 space-y-6">

      <%# Current credentials status %>
      <% if current_user.google_connected? %>
        <div class="flex items-center gap-3 p-3 rounded-lg bg-emerald-950/30 border border-emerald-800/40">
          <svg class="w-4 h-4 text-emerald-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
          <div class="text-xs min-w-0">
            <p class="text-gray-200 font-mono truncate"><%= current_user.gcp_service_account_email %></p>
            <p class="text-gray-500 mt-0.5">GCP project: <span class="text-gray-400"><%= current_user.gcp_project_from_key %></span></p>
          </div>
        </div>
      <% end %>

      <%# Step-by-step guide %>
      <div>
        <p class="text-xs font-semibold text-gray-300 mb-4">
          <%= current_user.google_connected? ? "To update your credentials, follow these steps:" : "Follow these steps to connect your Google Cloud account:" %>
        </p>

        <ol class="space-y-4">

          <%# Step 1 %>
          <li class="flex gap-4">
            <div class="flex-shrink-0 w-6 h-6 rounded-full bg-gray-800 border border-gray-700 flex items-center justify-center text-xs font-bold text-gray-400">1</div>
            <div class="flex-1 pt-0.5">
              <p class="text-sm text-gray-200">Open Google Cloud Console and select your project</p>
              <a href="https://console.cloud.google.com" target="_blank" rel="noopener"
                 class="inline-flex items-center gap-1 mt-1.5 text-xs text-indigo-400 hover:text-indigo-300 transition-colors">
                console.cloud.google.com
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
              </a>
            </div>
          </li>

          <%# Step 2 %>
          <li class="flex gap-4">
            <div class="flex-shrink-0 w-6 h-6 rounded-full bg-gray-800 border border-gray-700 flex items-center justify-center text-xs font-bold text-gray-400">2</div>
            <div class="flex-1 pt-0.5">
              <p class="text-sm text-gray-200">Go to <span class="font-medium">IAM & Admin → Service Accounts</span></p>
              <a href="https://console.cloud.google.com/iam-admin/serviceaccounts" target="_blank" rel="noopener"
                 class="inline-flex items-center gap-1 mt-1.5 text-xs text-indigo-400 hover:text-indigo-300 transition-colors">
                Open Service Accounts
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
              </a>
            </div>
          </li>

          <%# Step 3 %>
          <li class="flex gap-4">
            <div class="flex-shrink-0 w-6 h-6 rounded-full bg-gray-800 border border-gray-700 flex items-center justify-center text-xs font-bold text-gray-400">3</div>
            <div class="flex-1 pt-0.5">
              <p class="text-sm text-gray-200">Click <span class="font-medium">Create Service Account</span> and give it a name (e.g. <span class="font-mono text-gray-300">anchor-deploy</span>)</p>
            </div>
          </li>

          <%# Step 4 %>
          <li class="flex gap-4">
            <div class="flex-shrink-0 w-6 h-6 rounded-full bg-gray-800 border border-gray-700 flex items-center justify-center text-xs font-bold text-gray-400">4</div>
            <div class="flex-1 pt-0.5">
              <p class="text-sm text-gray-200 mb-2">Grant these four roles:</p>
              <div class="grid grid-cols-2 gap-1.5">
                <% [
                  ["Cloud Build Editor", "Build Docker images"],
                  ["Cloud Run Admin", "Deploy services"],
                  ["Artifact Registry Writer", "Push images"],
                  ["Service Account User", "Required by Cloud Run"]
                ].each do |role, desc| %>
                  <div class="px-2.5 py-2 rounded-lg bg-gray-800/60 border border-gray-700/60">
                    <p class="text-xs font-mono text-gray-200"><%= role %></p>
                    <p class="text-xs text-gray-500 mt-0.5"><%= desc %></p>
                  </div>
                <% end %>
              </div>
            </div>
          </li>

          <%# Step 5 %>
          <li class="flex gap-4">
            <div class="flex-shrink-0 w-6 h-6 rounded-full bg-gray-800 border border-gray-700 flex items-center justify-center text-xs font-bold text-gray-400">5</div>
            <div class="flex-1 pt-0.5">
              <p class="text-sm text-gray-200">Click the service account → <span class="font-medium">Keys</span> tab → <span class="font-medium">Add Key → Create new key → JSON</span></p>
              <p class="text-xs text-gray-500 mt-1">A <span class="font-mono">.json</span> file will download automatically.</p>
            </div>
          </li>

          <%# Step 6 %>
          <li class="flex gap-4">
            <div class="flex-shrink-0 w-6 h-6 rounded-full bg-gray-800 border border-gray-700 flex items-center justify-center text-xs font-bold text-gray-400">6</div>
            <div class="flex-1 pt-0.5">
              <p class="text-sm text-gray-200">Open the downloaded file, copy all the contents, and paste below.</p>
            </div>
          </li>

        </ol>
      </div>

      <%# Paste form %>
      <%= form_with url: gcp_credentials_settings_path, method: :patch do |f| %>
        <div class="space-y-3">
          <%= f.label :gcp_service_account_key,
                current_user.google_connected? ? "Replace service account key (JSON)" : "Paste service account key (JSON)",
                class: "block text-xs font-medium text-gray-400" %>
          <%= f.text_area :gcp_service_account_key,
                rows: 5,
                placeholder: '{"type": "service_account", "project_id": "my-project", "private_key_id": "...", ...}',
                class: "w-full rounded-lg bg-gray-800 border border-gray-700 text-gray-200 font-mono text-xs px-3 py-2.5 placeholder-gray-600 focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 resize-none" %>
          <div class="flex items-center justify-between">
            <p class="text-xs text-gray-600">Stored encrypted. Never shared or logged.</p>
            <%= f.submit current_user.google_connected? ? "Update credentials" : "Save credentials",
                  class: "text-sm font-medium bg-indigo-600 hover:bg-indigo-500 text-white px-4 py-2 rounded-lg transition-colors cursor-pointer" %>
          </div>
        </div>
      <% end %>

    </div>
  </div>
</div>
