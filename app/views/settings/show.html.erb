<% content_for :title, "Settings — Anchor" %>

<div class="max-w-2xl">
  <h1 class="text-2xl font-bold text-white mb-8">Settings</h1>

  <%# ── Google Cloud Credentials ─────────────────────────────────────── %>
  <div class="rounded-xl border border-gray-800 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-800">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-sm font-semibold text-white">Google Cloud</h2>
          <p class="text-xs text-gray-500 mt-0.5">Required to build and deploy your projects</p>
        </div>
        <% if current_user.google_connected? %>
          <span class="inline-flex items-center gap-1.5 text-xs font-medium text-emerald-400 bg-emerald-950/50 border border-emerald-800/50 px-2.5 py-1 rounded-full">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
            Connected
          </span>
        <% else %>
          <span class="inline-flex items-center gap-1.5 text-xs font-medium text-amber-400 bg-amber-950/50 border border-amber-800/50 px-2.5 py-1 rounded-full">
            <span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span>
            Not configured
          </span>
        <% end %>
      </div>
    </div>

    <div class="px-6 py-5 space-y-6">

      <%# ── OAuth (recommended) ──────────────────────────────────────── %>
      <div>
        <div class="flex items-center gap-2 mb-3">
          <p class="text-xs font-semibold text-gray-300">Connect with Google OAuth</p>
          <span class="text-xs text-emerald-400 bg-emerald-950/50 border border-emerald-800/50 px-2 py-0.5 rounded-full">Recommended</span>
        </div>

        <% if current_user.google_oauth_connected? %>
          <%# Connected state %>
          <div class="flex items-center justify-between p-3 rounded-lg bg-emerald-950/30 border border-emerald-800/40">
            <div class="flex items-center gap-3 min-w-0">
              <svg class="w-4 h-4 text-emerald-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
              <div class="min-w-0">
                <p class="text-xs text-gray-200 truncate"><%= current_user.connected_google_email %></p>
                <p class="text-xs text-gray-500 mt-0.5">Authenticated via Google OAuth</p>
              </div>
            </div>
            <%= button_to "Disconnect", google_disconnect_path, method: :delete,
                  class: "text-xs text-gray-400 hover:text-red-400 border border-gray-700 hover:border-red-800 px-3 py-1.5 rounded-lg transition-colors cursor-pointer flex-shrink-0" %>
          </div>
        <% else %>
          <%# Connect button %>
          <p class="text-xs text-gray-500 mb-3">Sign in with your Google account. No JSON key file needed — Anchor handles the rest.</p>
          <%= button_to "/auth/google_oauth2",
                method: :post,
                data: { turbo: false },
                class: "inline-flex items-center gap-2 text-sm font-medium bg-indigo-600 hover:bg-indigo-500 text-white px-4 py-2 rounded-lg transition-colors cursor-pointer" do %>
            <svg class="w-4 h-4" viewBox="0 0 24 24">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            Connect Google Cloud
          <% end %>
        <% end %>
      </div>

      <%# Divider %>
      <div class="flex items-center gap-3">
        <div class="flex-1 border-t border-gray-800"></div>
        <span class="text-xs text-gray-600">or use a service account key</span>
        <div class="flex-1 border-t border-gray-800"></div>
      </div>

      <%# ── Service Account Key (advanced / legacy) ─────────────────── %>
      <div>
        <p class="text-xs font-semibold text-gray-400 mb-1">Service Account Key <span class="font-normal text-gray-600">(advanced)</span></p>
        <div class="mb-3 p-2.5 rounded-lg bg-amber-950/20 border border-amber-900/30 text-xs text-amber-700">
          Use a service account with the <code class="text-amber-600">Editor</code> role.
          <strong class="text-amber-600">Firebase Admin SDK keys won't work</strong> — they lack Cloud Run and Cloud Build permissions.
          <a href="https://console.cloud.google.com/iam-admin/serviceaccounts" target="_blank" rel="noopener"
             class="text-amber-500 hover:text-amber-400 underline underline-offset-2 ml-1">Create one in GCP Console ↗</a>
        </div>

        <% if !current_user.google_oauth_connected? && current_user.gcp_service_account_key.present? %>
          <div class="flex items-center gap-3 p-3 rounded-lg bg-emerald-950/30 border border-emerald-800/40 mb-4">
            <svg class="w-4 h-4 text-emerald-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
            </svg>
            <div class="text-xs min-w-0">
              <p class="text-gray-200 truncate"><%= current_user.connected_google_email %></p>
              <p class="text-gray-500 mt-0.5">GCP project: <span class="text-gray-400"><%= current_user.gcp_project_from_key %></span></p>
            </div>
          </div>
        <% end %>

        <%= form_with url: gcp_credentials_settings_path, method: :patch do |f| %>
          <div class="space-y-3">
            <%= f.label :gcp_service_account_key,
                  current_user.gcp_service_account_key.present? ? "Replace service account key (JSON)" : "Paste service account key (JSON)",
                  class: "block text-xs font-medium text-gray-400" %>
            <%= f.text_area :gcp_service_account_key,
                  rows: 4,
                  placeholder: '{"type": "service_account", "project_id": "my-project", ...}',
                  class: "w-full rounded-lg bg-gray-800 border border-gray-700 text-gray-200 font-mono text-xs px-3 py-2.5 placeholder-gray-600 focus:outline-none focus:border-gray-500 focus:ring-1 focus:ring-gray-500 resize-none" %>
            <div class="flex items-center justify-between">
              <p class="text-xs text-gray-600">Stored encrypted. Never shared or logged.</p>
              <%= f.submit current_user.gcp_service_account_key.present? ? "Update key" : "Save key",
                    class: "text-sm font-medium bg-indigo-600 hover:bg-indigo-500 text-white px-4 py-2 rounded-lg transition-colors cursor-pointer" %>
            </div>
          </div>
        <% end %>
      </div>

    </div>
  </div>
</div>
